# FRED API credentials
# Get your free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Snowflake connection
SNOWFLAKE_ACCOUNT=your_account.region.cloud    # e.g., abc12345.us-east-1.aws
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=ACCOUNTADMIN                     # Or a dedicated role with RAW schema access
SNOWFLAKE_WAREHOUSE=FRED_WH
SNOWFLAKE_DATABASE=FRED_PIPELINE

# dbt target environment (dev/prod)
DBT_TARGET=dev